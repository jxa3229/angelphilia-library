{
  "name": "angelphilia-library",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:data": "node scripts/extract-library-data.mjs",
    "sync:details": "node scripts/extract-docx-details.mjs",
    "prepare:public": "node scripts/prepare-public.mjs",
    "dev": "npm run sync:data && npm run sync:details && npm run prepare:public && vite --host 127.0.0.1",
